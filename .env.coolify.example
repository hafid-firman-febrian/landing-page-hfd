# =============================================================
# Environment variables to set in Coolify (Application → Env)
# Copy these into Coolify — do NOT commit real secrets to git.
# =============================================================

APP_NAME="HFD"
APP_ENV=production
APP_DEBUG=false
# Generate locally with: php artisan key:generate --show
APP_KEY=
# Your public domain (Coolify sets this automatically if you use its domain).
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database (MySQL service created in Coolify) -------------
DB_CONNECTION=mysql
DB_HOST=mysql            # the internal service name/host from Coolify
DB_PORT=3306
DB_DATABASE=landing_hfd
DB_USERNAME=hfd
DB_PASSWORD=change-me

# --- Sessions / cache / queue (database-backed) -------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

# --- Filesystem (uploaded images live on the public disk) ----
FILESYSTEM_DISK=public

# --- Mail (adjust to your provider; defaults to log) ---------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"
