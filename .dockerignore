# Version control
.git
.gitignore
.gitattributes

# Dependencies (installed inside the image)
/vendor
/node_modules

# Build output (regenerated in the image)
/public/build
/public/hot

# Local environment & secrets
.env
.env.*
!.env.example

# Local SQLite database
/database/*.sqlite
/database/*.sqlite-*

# Runtime / cache
/storage/logs/*
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
bootstrap/cache/*.php

# Tooling / editor / OS junk
/.idea
/.vscode
/.fleet
.DS_Store
Thumbs.db

# Tests & docs (not needed at runtime)
/tests
/.github
/docs
README.md
